# Copy to `.env` locally. Never commit real secrets.
# Deployed HTTPS API only — no localhost/Herd/LAN URLs in distributed builds.

# Required: Laravel origin for internal mobile + authenticated API (HTTPS, no trailing slash recommended)
# Local dev: set in .env. EAS preview/testflight/production set this in eas.json for store-style builds.
EXPO_PUBLIC_API_BASE_URL=

# Legacy path used by older client flows; internal mobile uses /api/v1/internal-mobile/* only.
EXPO_PUBLIC_API_AUTH_PATH=/api/mobile/login

# Optional local label; EAS profiles set EXPO_PUBLIC_APP_CHANNEL automatically in eas.json
EXPO_PUBLIC_APP_CHANNEL=local

# Google Sign-In (native). Set the client IDs issued for this app’s bundle ID / package name.
# iOS builds need EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID; Android typically needs Android client ID and/or web client ID.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# When true, shows password fields that call POST /api/v1/internal-mobile/auth/password (must match Laravel INTERNAL_MOBILE_PASSWORD_AUTH_ENABLED).
EXPO_PUBLIC_INTERNAL_MOBILE_PASSWORD_AUTH_ENABLED=false
